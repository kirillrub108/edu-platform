# Agent
.claude
CLAUDE.local.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.venv/
venv/
env/

# Environment
.env
.env.local
# Production secrets — only the .example template is committed.
.env.prod

# IDE
.idea/
*.swp
*.swo
.vscode

# OS
.DS_Store
Thumbs.db

# Storage
backend/storage/*
!backend/storage/.gitkeep

#Pylance
backend/.stubs/

# Alembic
backend/alembic/versions/*
!backend/alembic/versions/.gitkeep

# Node
node_modules/
.output/
dist/
.cache/

# Nuxt generated output — ignored everywhere ...
.nuxt/
# ... except the tsconfig stub that lets VS Code resolve types before the
# container first runs (Nuxt overwrites it with the real config on startup).
!frontend/.nuxt/
frontend/.nuxt/*
!frontend/.nuxt/tsconfig.json

# Logs
*.log

# Python test / lint / type caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml

# ML model weights (e.g. Silero .pt pulled into the tts volume at runtime)
*.pt
*.onnx

# Database dumps & backups (pg_dump / db_backup sidecar)
*.sql
*.dump
*.bak
db_backups/
backups/

# TLS material & ACME data — never commit private keys or issued certs
*.pem
*.key
*.crt
*.p12
*.pfx
letsencrypt/
certbot/
