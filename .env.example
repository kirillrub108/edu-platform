# PostgreSQL
POSTGRES_USER=edu_user
POSTGRES_PASSWORD=edu_password
POSTGRES_DB=edu_platform
DATABASE_URL=postgresql+asyncpg://edu_user:edu_password@postgres:5432/edu_platform

# Redis
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=120      # sliding window — выживет каникулы
REFRESH_TOKEN_ABSOLUTE_MAX_DAYS=365  # раз в год принудительный логин

# LLM (OpenAI-compatible interface)
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=qwen3:8b
LLM_API_KEY=ollama
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# LLM used to refine vision output during single-slide regeneration
REGEN_LLM_MODEL=qwen3:8b

# Vision LLM (per-slide narration)
VISION_PROVIDER=ollama          # ollama | yandex
VISION_MODEL=qwen2.5vl:7b
VISION_OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
VISION_API_KEY=ollama

# YandexGPT Pro (production vision)
YANDEX_VISION_MODEL=yandexgpt-pro
YANDEX_FOLDER_ID=
YANDEX_API_KEY=

# TTS
TTS_PROVIDER=silero
SILERO_TTS_URL=http://silero-tts:9898

# Storage
STORAGE_PATH=/app/storage
BASE_URL=http://localhost:8000

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Cookies (httpOnly JWT + CSRF double-submit)
# COOKIE_SECURE=false   # set true in production (HTTPS only)
# COOKIE_SAMESITE=Lax   # Lax works with the Nitro devProxy (same-origin in dev)

# Frontend API base — override in production when frontend and backend are on
# different origins behind nginx:
# NUXT_PUBLIC_API_BASE=http://backend:8000/api/v1
