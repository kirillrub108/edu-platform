# PostgreSQL
POSTGRES_USER=edu_user
POSTGRES_PASSWORD=edu_password
POSTGRES_DB=edllm
DATABASE_URL=postgresql+asyncpg://edu_user:edu_password@postgres:5432/edllm

# Redis
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=120      # sliding window — выживет каникулы
REFRESH_TOKEN_ABSOLUTE_MAX_DAYS=365  # раз в год принудительный логин

# Billing admin — shared secret for /api/v1/billing/admin/* (X-Admin-Token header).
# Empty disables admin endpoints (grant / renewal).
ADMIN_API_TOKEN=

# LLM (OpenAI-compatible interface) — Polza AI by default.
# Provider is swapped by editing ONLY these values (no code change):
#   Yandex AI Studio: LLM_BASE_URL=https://llm.api.cloud.yandex.net/v1 + its model slug + key
#   Local Ollama:     LLM_BASE_URL=http://host.docker.internal:11434/v1, LLM_MODEL=qwen3:8b, LLM_API_KEY=ollama
LLM_BASE_URL=https://api.polza.ai/v1
LLM_MODEL=qwen/qwen3-30b-a3b-instruct-2507
LLM_API_KEY=pza_...
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
# Pin the Polza upstream provider for the text model (cheapest on in+out tokens).
# Comma-separated display names; allow_fallbacks is always on. Empty → Polza
# picks. Leave empty for local Ollama (it does not understand this field).
LLM_PROVIDER_ORDER=StreamLake

# Text LLM that refines vision output during single-slide regeneration.
# On a cloud provider point this at the same text model as LLM_MODEL.
REGEN_LLM_MODEL=qwen/qwen3-30b-a3b-instruct-2507

# Vision LLM (per-slide narration). Routed through the generic OpenAI-compatible
# branch (VISION_PROVIDER=ollama) — same branch serves Polza AND Yandex AI Studio.
# Revert to local: VISION_MODEL=qwen2.5vl:7b, VISION_OLLAMA_BASE_URL=http://host.docker.internal:11434/v1, VISION_API_KEY=ollama
VISION_PROVIDER=ollama          # ollama (generic OpenAI) | yandex (native Yandex Cloud)
# ВАЖНО: модель должна реально принимать image_url через роутинг Polza
# (qwen3.6-35b-a3b, например, развёрнута только у Yandex без мультимодальности).
VISION_MODEL=qwen/qwen3.6-27b
# Отключает скрытое reasoning у thinking-моделей через OpenRouter-параметр
# reasoning:{enabled:false} (Polza его понимает). Для локального Ollama / Yandex
# оставить false — параметр им не отправляется.
VISION_REASONING_DISABLED=true
VISION_OLLAMA_BASE_URL=https://api.polza.ai/v1
VISION_API_KEY=pza_...
# Pin the Polza upstream provider for the vision model (cheapest output token
# price, full 262K context). allow_fallbacks rolls to a working provider if this
# one is down or does not actually accept image_url. Empty → Polza picks.
VISION_PROVIDER_ORDER=Chutes

# YandexGPT Pro (production vision)
YANDEX_VISION_MODEL=yandexgpt-pro
YANDEX_FOLDER_ID=
YANDEX_API_KEY=

# Email — transactional mail (verification, video-ready notifications).
# Sent only from the send_email Celery task (celery_email queue). Provider is
# pluggable; "resend" is implemented today. Leave RESEND_API_KEY empty in dev
# (the send_email task will retry and fail without a key — no other side effects).
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=Edllm <no-reply@send.edllm.ru>
# Public origin of the SPA — used to build verify/redirect/lesson links.
FRONTEND_URL=http://localhost:3000

# TTS: silero (локальный контейнер, дефолт) или polza (облачный шлюз, openai/tts-1)
TTS_PROVIDER=silero
SILERO_TTS_URL=http://silero-tts:9898
# Для TTS_PROVIDER=polza (остальные POLZA_* имеют дефолты в config.py):
#POLZA_API_KEY=
#POLZA_TTS_MODEL=openai/tts-1

# Storage backend: "local" (default) or "s3"
STORAGE_BACKEND=local
STORAGE_PATH=/app/storage
BASE_URL=http://localhost:8000

# Static delivery (local backend). Dev default false → FastAPI serves /files/*.
# In prod set true → nginx serves /files/* directly from disk (sendfile) and
# FastAPI only exposes the internal auth_request verify endpoint.
SERVE_STATIC_VIA_NGINX=false
# Public host signed /files/* links point at (nginx/CDN domain) in prod, e.g.
# https://cdn.edllm.ru. Empty → falls back to BASE_URL (dev).
PUBLIC_FILES_BASE_URL=

# S3-compatible storage — required when STORAGE_BACKEND=s3.
# Yandex Object Storage endpoint; replace with your provider's URL if different.
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=ru-central1
# Presigned URL lifetime in seconds (default 1 hour)
S3_PRESIGNED_URL_EXPIRE_SECONDS=3600

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Cookies (httpOnly JWT + CSRF double-submit)
# COOKIE_SECURE=false   # set true in production (HTTPS only)
# COOKIE_SAMESITE=Lax   # Lax works with the Nitro devProxy (same-origin in dev)

# Frontend API base — override in production when frontend and backend are on
# different origins behind nginx:
# NUXT_PUBLIC_API_BASE=http://backend:8000/api/v1

# Grafana — metrics dashboard (http://localhost:3001)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me

# Flower — Celery monitoring UI (http://localhost:5555)
CELERY_FLOWER_USER=admin
CELERY_FLOWER_PASSWORD=change-me

# Sentry — leave SENTRY_DSN empty to disable entirely (no side effects).
# Get DSN from: https://sentry.io → Project Settings → Client Keys (DSN).
SENTRY_DSN=
ENVIRONMENT=development
APP_VERSION=dev
# Fraction of requests/tasks sampled for performance traces (0.0–1.0).
SENTRY_TRACES_SAMPLE_RATE=0.1
