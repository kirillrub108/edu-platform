# ─────────────────────────────────────────────────────────────────────────────
# Production env template for docker-compose.prod.yml. Copy to `.env.prod` on
# the VM and fill every CHANGE_ME. NEVER commit the filled .env.prod.
#   cp .env.prod.example .env.prod  &&  edit
# Run compose with:  docker compose -f docker-compose.prod.yml --env-file .env.prod ...
# Generate strong secrets:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Image refs ───────────────────────────────────────────────────────────────
# CD overrides these with the YCR tag (cr.yandex/<registry-id>/backend:<sha>).
# Defaults build/run locally.
BACKEND_IMAGE=edllm-backend:local
FRONTEND_IMAGE=edllm-frontend:local

# ── Runtime ──────────────────────────────────────────────────────────────────
ENVIRONMENT=production
APP_VERSION=prod
# uvicorn workers under gunicorn. Rule of thumb: ~ (2 * vCPU) + 1.
GUNICORN_WORKERS=4
# Prod: migrations run as a one-shot deploy step (the `migrate` service), NOT in
# the app lifespan. Keep false.
RUN_MIGRATIONS_ON_STARTUP=false

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=edu_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=edllm
DATABASE_URL=postgresql+asyncpg://edu_user:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/edllm

# ── DB backup (db_backup sidecar) ─────────────────────────────────────────────
# Periodic pg_dump → db_backups volume. Optional; these defaults apply if unset.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0

# ── JWT / sessions ───────────────────────────────────────────────────────────
# REQUIRED — no default in prod. openssl rand -hex 32
SECRET_KEY=CHANGE_ME_OPENSSL_RAND_HEX_32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=120
REFRESH_TOKEN_ABSOLUTE_MAX_DAYS=365

# ── Domain / TLS (nginx + certbot) ───────────────────────────────────────────
# The single canonical domain. nginx (server_name + Let's Encrypt cert path,
# via envsubst on nginx/prod.conf.template) and deploy/init-letsencrypt.sh both
# read DOMAIN, and Grafana's root URL derives from it. To serve a fork under a
# different domain, change DOMAIN here and update the https://... URLs below to
# match.
DOMAIN=edllm.ru
# Let's Encrypt contact address (certbot --email) for expiry notices.
CERTBOT_EMAIL=CHANGE_ME_letsencrypt@example.com

# ── Public origin / HTTPS auth ───────────────────────────────────────────────
# Single domain: frontend, /api and /files all behind nginx on https://edllm.ru
FRONTEND_URL=https://edllm.ru
BASE_URL=https://edllm.ru
CORS_ORIGINS=https://edllm.ru
# Cookies must be Secure over HTTPS. Lax is fine since front+API are same-origin.
COOKIE_SECURE=true
COOKIE_SAMESITE=Lax

# ── Static delivery (local storage via nginx) ────────────────────────────────
STORAGE_BACKEND=local
STORAGE_PATH=/app/storage
# Prod: nginx serves /files/* from disk; FastAPI only verifies signatures.
SERVE_STATIC_VIA_NGINX=true
# Public host signed /files/* links point at (same single domain).
PUBLIC_FILES_BASE_URL=https://edllm.ru

# ── LLM (OpenAI-compatible) — Polza today; switch to Yandex AI Studio later ──
# Yandex AI Studio also speaks the OpenAI protocol, so the swap is env-only:
#   LLM_BASE_URL=https://llm.api.cloud.yandex.net/v1
#   LLM_MODEL=<yandex model slug>
#   LLM_API_KEY=<IAM or Api-Key>
LLM_BASE_URL=https://api.polza.ai/v1
LLM_MODEL=qwen/qwen3-30b-a3b-instruct-2507
LLM_API_KEY=CHANGE_ME_LLM_API_KEY
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_PROVIDER_ORDER=StreamLake
REGEN_LLM_MODEL=qwen/qwen3-30b-a3b-instruct-2507

# ── Vision LLM — Polza today; Yandex Vision later (no code change) ────────────
# Yandex path: VISION_PROVIDER=yandex + YANDEX_FOLDER_ID + YANDEX_API_KEY below.
VISION_PROVIDER=ollama
VISION_MODEL=qwen/qwen3.6-27b
VISION_REASONING_DISABLED=true
VISION_OLLAMA_BASE_URL=https://api.polza.ai/v1
VISION_API_KEY=CHANGE_ME_VISION_API_KEY
VISION_PROVIDER_ORDER=Chutes

# YandexGPT / Yandex Vision (fill when switching VISION_PROVIDER=yandex)
YANDEX_VISION_MODEL=yandexgpt-pro
YANDEX_FOLDER_ID=
YANDEX_API_KEY=

# ── TTS ──────────────────────────────────────────────────────────────────────
# Stays on the Silero container in prod. (Yandex SpeechKit would require a code
# change in services/tts_service.py — out of scope here.)
# LICENSING: Silero's Russian models (v5_ru/v5_5_ru) are CC-BY-NC 4.0 — free ONLY
# for NON-COMMERCIAL use. A commercial deployment needs a Silero Enterprise licence
# (hello@silero.ai) or a commercial provider (TTS_PROVIDER=polza / Yandex SpeechKit).
# See THIRD_PARTY_LICENSES.md.
TTS_PROVIDER=silero
SILERO_TTS_URL=http://silero-tts:9898

# ── Email (transactional) ────────────────────────────────────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
EMAIL_FROM=Edllm <no-reply@send.edllm.ru>

# ── Billing admin (optional) — empty disables /billing/admin/* ───────────────
ADMIN_API_TOKEN=

# ── YooKassa (optional) — empty SHOP_ID/SECRET_KEY disables payments ─────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=
YOOKASSA_SEND_RECEIPT=false
YOOKASSA_VAT_CODE=1

# ── Sentry (optional, error tracking) ────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
